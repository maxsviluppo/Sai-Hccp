
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-down {
      animation: slideDown 0.2s ease-out forwards;
    }

    @media print {
      body * {
        visibility: hidden;
      }
      #print-template, #print-template * {
        visibility: visible;
      }
      #print-template {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
      }
    }
  