
    @keyframes slideInRight {
      from { transform: translateX(400px); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    @keyframes shrink {
      from { width: 100%; }
      to { width: 0%; }
    }
    .animate-slide-in-right {
      animation: slideInRight 0.3s ease-out;
    }
    .animate-shrink {
      animation: shrink linear;
    }
  